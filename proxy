def stop_proxy():
    runtime = detect_runtime()
    service = runtime["service"]
    try:
        unit = run(["systemctl", "cat", service], timeout=8)
    except Exception:
        unit = None
    if unit is None or unit.returncode != 0:
        cleanup_env_file()
        clear_global_env_file()
        print("未检测到代理服务，已清理 shell / 系统代理环境变量")
        return True

    errors = []
    for action in ("stop", "disable"):
        try:
            result = run(["systemctl", action, service], timeout=15)
            if result.returncode != 0:
                errors.append(f"systemctl {action}: {command_error(result)}")
        except Exception as e:
            errors.append(f"systemctl {action}: {type(e).__name__}: {e}")
    cleanup_env_file()
    clear_global_env_file()
    if errors:
        print("代理环境变量已清理，但服务停止/禁用存在错误:")
        for error in errors:
            print(f"  - {error}")
        return False
    print("代理已停止")
    print("  已关闭本地监听，并清理 shell / 系统代理环境变量")
    return True




def print_ip_result(data, source=None, prefix="  "):
    ip = data.get("query") or data.get("ip") or data.get("origin") or "?"
    print(f"{prefix}IP:    {ip}")
    if data.get("country") or data.get("countryCode"):
