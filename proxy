def env_port(name, default):
    raw = os.environ.get(name, "").strip()
    if not raw:
        return default
    try:
        port = int(raw)
    except ValueError as e:
        raise ValueError(f"{name} 必须是端口数字: {raw}") from e
    if not 1 <= port <= 65535:
        raise ValueError(f"{name} 必须在 1-65535 之间: {port}")
    return port


def with_env_override(name, defaults):
    value = os.environ.get(name, "").strip()
    return [value, *defaults] if value else list(defaults)


def atomic_write_text(path, content, mode=None):
    path = Path(path)
    if path.is_symlink():
        path = path.resolve()
    path.parent.mkdir(parents=True, exist_ok=True)
    file_mode = mode
    if path.exists():
        file_mode = path.stat().st_mode & 0o777

    fd, temporary = tempfile.mkstemp(prefix=f".{path.name}.", dir=str(path.parent))
    temporary_path = Path(temporary)
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as f:
            f.write(content)
            f.flush()
            os.fsync(f.fileno())
        if file_mode is not None:
            os.chmod(temporary_path, file_mode)
        os.replace(temporary_path, path)
    finally:
        if temporary_path.exists():
            temporary_path.unlink()


def atomic_write_json(path, data, mode=0o600):
    content = json.dumps(data, indent=2, ensure_ascii=False) + "\n"
    atomic_write_text(path, content, mode=mode)


