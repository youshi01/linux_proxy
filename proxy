def remove_subscription(index_text):
    subs = load_subscriptions()
    if not subs:
        print("没有可删除的订阅")
        return False
    try:
        idx = int(index_text) - 1
    except ValueError:
        print("订阅编号必须是数字")
        return False
    if idx < 0 or idx >= len(subs):
        print(f"无效订阅编号: {index_text}")
        return False
    removed = subs.pop(idx)
    save_subscriptions(subs)
    print(f"已删除订阅: {removed.get('name') or removed.get('url')}")
    if subs:
        return import_from_subscriptions(verbose=True)
    save_config(base_config())
    print("订阅已清空，节点列表已清空")
    return True


