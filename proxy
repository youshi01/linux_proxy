    subs = load_subscriptions()
    print(f"\n{'='*56}")
    print("  订阅列表")
    print(f"{'='*56}")
    if not subs:
        print("  (空)")
    for i, sub in enumerate(subs, 1):
        status = "启用" if sub.get("enabled", True) else "禁用"
        print(f"  {i}. [{status}] {sub.get('name') or '未命名'}")
        print(f"     {sub.get('url', '')}")
