def parse_config_path_from_unit(text):
    for line in text.splitlines():
        if "ExecStart=" not in line:
            continue
        command = line.split("ExecStart=", 1)[1].strip()
        try:
            args = shlex.split(command)
        except ValueError:
            args = command.split()

        for i, arg in enumerate(args):
            if arg in {"-config", "--config", "-c"} and i + 1 < len(args):
                return args[i + 1]
            if arg.startswith(("-config=", "--config=")):
                return arg.split("=", 1)[1]
            if arg in {"-confdir", "--confdir"} and i + 1 < len(args):
                return str(PurePosixPath(args[i + 1]) / "config.json")
            if arg.startswith(("-confdir=", "--confdir=")):
                return str(PurePosixPath(arg.split("=", 1)[1]) / "config.json")

    patterns = [r"-config\s+['\"]?([^'\"\s]+)", r"\s-c\s+['\"]?([^'\"\s]+)"]
    for pattern in patterns:
        match = re.search(pattern, text)
        if match:
            return match.group(1)
    return None


def detect_runtime():
    for service in SERVICE_CANDIDATES:
        try:
            r = run(["systemctl", "cat", service], timeout=8)
        except (OSError, subprocess.SubprocessError):
            continue
        if r.returncode == 0:
            cfg = parse_config_path_from_unit(r.stdout)
            if cfg:
                return {"service": service, "config_file": cfg, "source": "systemd"}
            for candidate in CONFIG_CANDIDATES:
                if Path(candidate).exists():
                    return {"service": service, "config_file": candidate, "source": "mixed"}
            return {"service": service, "config_file": CONFIG_CANDIDATES[0], "source": "systemd"}

    for candidate in CONFIG_CANDIDATES:
        if Path(candidate).exists():
            guessed = "xray" if "xray" in candidate else "v2ray"
            return {"service": guessed, "config_file": candidate, "source": "path"}

    return {"service": "xray", "config_file": CONFIG_CANDIDATES[1], "source": "default"}


def load_config():
    runtime = detect_runtime()
    path = Path(runtime["config_file"])
    if not path.exists():
        return base_config()
    with open(path) as f:
        return json.load(f)


def backup_config(path):
    p = Path(path)
    if not p.exists():
        return
    backup = p.with_name(p.name + f".bak.{time.time_ns()}")
    shutil.copy2(p, backup)


def save_config(cfg):
    runtime = detect_runtime()
    path = Path(runtime["config_file"])
    path.parent.mkdir(parents=True, exist_ok=True)
    if path.exists():
        backup_config(path)
    atomic_write_json(path, cfg)


def get_nodes():
    return load_config().get("outbounds", [])


def get_current_tag():
    rules = load_config().get("routing", {}).get("rules", [])
    return rules[0].get("outboundTag", "unknown") if rules else "unknown"


def resolve_tag(arg):
    nodes = get_nodes()
    try:
        idx = int(arg) - 1
        if 0 <= idx < len(nodes):
            return nodes[idx]["tag"]
    except ValueError:
        pass
    valid_tags = [n["tag"] for n in nodes]
    if arg in valid_tags:
        return arg
    return None


def service_is_active(service):
    try:
        r = run(["systemctl", "is-active", service], timeout=5)
        return r.stdout.strip() == "active"
    except Exception:
        return False


def check_service():
    runtime = detect_runtime()
    return service_is_active(runtime["service"])


def socks_inbound_ready(timeout=0.5):
    try:
        with socket.create_connection(("127.0.0.1", SOCKS_PORT), timeout=timeout) as sock:
            sock.settimeout(timeout)
            sock.sendall(b"\x05\x01\x00")
            return sock.recv(2) == b"\x05\x00"
    except Exception:
        return False


def http_inbound_ready(timeout=0.5):
    try:
        with socket.create_connection(("127.0.0.1", HTTP_PORT), timeout=timeout):
            return True
    except Exception:
        return False


def wait_for_proxy_ready(service, timeout=8):
    deadline = time.monotonic() + timeout
    active = socks_ok = http_ok = False
    while True:
        active = service_is_active(service)
        socks_ok = socks_inbound_ready()
        http_ok = http_inbound_ready()
        if active and socks_ok and http_ok:
            return True, ""
        if time.monotonic() >= deadline:
            break
        time.sleep(0.25)

    missing = []
    if not active:
        missing.append("systemd 服务未处于 active")
    if not socks_ok:
        missing.append(f"SOCKS5 127.0.0.1:{SOCKS_PORT} 未就绪")
    if not http_ok:
        missing.append(f"HTTP 127.0.0.1:{HTTP_PORT} 未就绪")
    return False, "；".join(missing)


def ensure_proxy_running(runtime):
    service = runtime["service"]
    try:
        result = run(["systemctl", "enable", service, "--now"], timeout=15)
    except Exception as e:
        print(f"启动代理服务失败: {type(e).__name__}: {e}")
        return False

    if result.returncode != 0:
        error = result.stderr.strip() or result.stdout.strip() or f"退出码 {result.returncode}"
        print(f"启动代理服务失败: systemctl enable {service} --now")
        print(f"  {error}")
        return False

    ready, reason = wait_for_proxy_ready(service)
    if not ready:
        print(f"代理服务未就绪: {reason}")
        print(f"  可检查日志: journalctl -u {service} -n 50 --no-pager")
        return False
    return True


def command_error(result):
    return result.stderr.strip() or result.stdout.strip() or f"退出码 {result.returncode}"


def restart_proxy_service(runtime, verify=True):
    service = runtime["service"]
    try:
        result = run(["systemctl", "restart", service], timeout=15)
    except Exception as e:
        print(f"重启代理服务失败: {type(e).__name__}: {e}")
        return False
    if result.returncode != 0:
        print(f"重启代理服务失败: {service}")
        print(f"  {command_error(result)}")
        return False
    if verify:
        ready, reason = wait_for_proxy_ready(service)
        if not ready:
            print(f"代理服务重启后未就绪: {reason}")
            print(f"  可检查日志: journalctl -u {service} -n 50 --no-pager")
            return False
    return True


def cleanup_env_file():
    if os.path.exists(PROXY_SH):
        os.remove(PROXY_SH)


def remove_env_vars_from_text(text):
    lines = text.splitlines()
    filtered = []
    keys = {line.split("=", 1)[0] for line in PROXY_ENV_LINES}
    for line in lines:
        stripped = line.strip()
        if any(stripped.startswith(k + "=") for k in keys):
            continue
        filtered.append(line)
    return "\n".join(filtered).strip("\n")


def write_profile_env_file():
    content = "\n".join([f"export {line}" for line in PROXY_ENV_LINES]) + "\n"
    atomic_write_text(PROXY_SH, content, mode=0o644)


def write_global_env_file():
    existing = Path(ENV_FILE).read_text() if os.path.exists(ENV_FILE) else ""
    cleaned = remove_env_vars_from_text(existing)
    final = (cleaned + "\n" if cleaned else "") + "\n".join(PROXY_ENV_LINES) + "\n"
    atomic_write_text(ENV_FILE, final, mode=0o644)


def clear_global_env_file():
    if not os.path.exists(ENV_FILE):
        return
    existing = Path(ENV_FILE).read_text()
    cleaned = remove_env_vars_from_text(existing)
    atomic_write_text(ENV_FILE, (cleaned + "\n") if cleaned else "", mode=0o644)


def apply_mode(mode):
    cleanup_env_file()
    clear_global_env_file()
    if mode == "outbound":
        write_profile_env_file()
    elif mode == "global":
        write_profile_env_file()
        write_global_env_file()
    save_mode(mode)


def unique_tag(tag, seen):
    base = tag or "NODE"
    if base not in seen:
        seen.add(base)
        return base
    i = 2
    while f"{base}-{i}" in seen:
        i += 1
    final = f"{base}-{i}"
    seen.add(final)
    return final


def looks_like_subscription_text(text):
    return any(re.match(r"^[a-z][a-z0-9+.-]*://", line.strip(), re.I) for line in text.splitlines())


def decode_subscription_text(raw):
    raw = raw.strip()
    if not raw or looks_like_subscription_text(raw):
        return raw

    compact = re.sub(r"\s+", "", raw)
    padded = compact + "=" * (-len(compact) % 4)
    for altchars in (None, b"-_"):
        try:
            decoded = base64.b64decode(padded, altchars=altchars, validate=True).decode("utf-8")
        except (binascii.Error, ValueError, UnicodeDecodeError):
            continue
        if looks_like_subscription_text(decoded):
            return decoded.strip()
    return raw


def fetch_subscription_text(url):
    req = urllib.request.Request(url, headers={"User-Agent": "Mozilla/5.0"})
    with urllib.request.urlopen(req, timeout=20) as resp:
        raw = resp.read().decode("utf-8", "ignore").strip()
    return decode_subscription_text(raw)


def build_vless_outbound(uri, seen_tags):
    u = urlparse(uri)
    if u.scheme.lower() != "vless":
        return None
    try:
        port = u.port
    except ValueError:
        return None
    if not u.hostname or not port or not u.username:
        return None
    q = parse_qs(u.query)
    tag = unique_tag(unquote(u.fragment) if u.fragment else (u.hostname or "NODE"), seen_tags)
    host = q.get("host", [""])[0]
    path = q.get("path", [""])[0] or q.get("spx", [""])[0] or "/"
    flow = q.get("flow", [""])[0]
    fingerprint = q.get("fp", [""])[0] or "chrome"
    sni = q.get("sni", [""])[0] or q.get("servername", [""])[0]
    network = q.get("type", ["tcp"])[0]
    security = q.get("security", [""])[0]

    user = {
        "id": unquote(u.username),
        "encryption": q.get("encryption", ["none"])[0],
    }
    if flow:
        user["flow"] = flow

    stream_settings = {"network": network, "security": security}
    if security == "reality":
        stream_settings["realitySettings"] = {
            "serverName": sni,
            "fingerprint": fingerprint,
            "publicKey": q.get("pbk", [""])[0],
            "shortId": q.get("sid", [""])[0],
            "spiderX": q.get("spx", ["/"])[0] or "/",
        }
    elif security in {"tls", "xtls"}:
        tls_settings = {"serverName": sni, "fingerprint": fingerprint}
        alpn = q.get("alpn", [""])[0]
        if alpn:
            tls_settings["alpn"] = [item.strip() for item in alpn.split(",") if item.strip()]
        allow_insecure = q.get("allowInsecure", q.get("insecure", [""]))[0].lower()
        if allow_insecure in {"1", "true", "yes"}:
            tls_settings["allowInsecure"] = True
        stream_settings["tlsSettings"] = tls_settings

    outbound = {
        "protocol": "vless",
        "settings": {
            "vnext": [
                {
                    "address": u.hostname or "",
                    "port": port,
                    "users": [user],
                }
            ]
        },
        "streamSettings": stream_settings,
        "tag": tag,
    }

    if network == "tcp":
        header_type = q.get("headerType", q.get("header", ["none"]))[0] or "none"
        outbound["streamSettings"]["tcpSettings"] = {"header": {"type": header_type}}
    elif network == "ws":
        ws_settings = {"path": path}
        if host:
            ws_settings["headers"] = {"Host": host}
        outbound["streamSettings"]["wsSettings"] = ws_settings
    elif network == "grpc":
        service_name = q.get("serviceName", [""])[0] or path.lstrip("/")
        outbound["streamSettings"]["grpcSettings"] = {"serviceName": service_name}
    return outbound


def import_from_subscriptions(verbose=True):
    subs = [s for s in load_subscriptions() if s.get("enabled", True) and s.get("url")]
    if not subs:
        print("没有可用订阅，请先执行: proxy 00 <订阅链接>")
        return False

    all_nodes = []
    seen_tags = set()
    for sub in subs:
        try:
            text = fetch_subscription_text(sub["url"])
            lines = [x.strip() for x in text.splitlines() if x.strip()]
            imported = 0
            ignored = 0
            for line in lines:
                try:
                    node = build_vless_outbound(line, seen_tags)
                except Exception:
                    node = None
                if node:
                    all_nodes.append(node)
                    imported += 1
                else:
                    ignored += 1
            if verbose:
                message = f"订阅 [{sub.get('name') or '未命名'}] 已更新，导入 {imported} 个节点"
                if ignored:
                    message += f"，忽略 {ignored} 条不支持或无效记录"
                print(message)
        except urllib.error.HTTPError as e:
            print(f"订阅 [{sub.get('name') or '未命名'}] 更新失败: HTTP {e.code}")
        except Exception as e:
            print(f"订阅 [{sub.get('name') or '未命名'}] 更新失败: {e}")

    if not all_nodes:
        print("没有从订阅中导入任何可用节点")
        return False

    old = load_config()
    cfg = base_config()
    cfg["outbounds"] = all_nodes
    current = old.get("routing", {}).get("rules", [{}])[0].get("outboundTag", "") if old else ""
    valid_tags = [n["tag"] for n in all_nodes]
    selected = current if current in valid_tags else valid_tags[0]
    cfg["routing"]["rules"][0]["outboundTag"] = selected
    save_config(cfg)
    if verbose:
        print(f"已写入 {len(all_nodes)} 个节点，当前节点: {selected}")
    return True


def outbound_to_vless_uri(node):
    try:
        import urllib.parse
        tag = node.get("tag", "NODE")
        vnext = node.get("settings", {}).get("vnext", [{}])[0]
        user = vnext.get("users", [{}])[0]
        stream = node.get("streamSettings", {})
        reality = stream.get("realitySettings", {})
        tls = stream.get("tlsSettings", {})
        network = stream.get("network", "tcp")
        security = stream.get("security", "")
        params = {
            "encryption": user.get("encryption", "none"),
            "type": network,
            "security": security,
            "flow": user.get("flow", ""),
        }
        if security == "reality":
            params.update({
                "pbk": reality.get("publicKey", ""),
                "sid": reality.get("shortId", ""),
                "sni": reality.get("serverName", ""),
                "fp": reality.get("fingerprint", ""),
                "spx": reality.get("spiderX", "/"),
            })
        elif security in {"tls", "xtls"}:
            params.update({
                "sni": tls.get("serverName", ""),
                "fp": tls.get("fingerprint", ""),
                "alpn": ",".join(tls.get("alpn", [])),
                "allowInsecure": "1" if tls.get("allowInsecure") else "",
            })

        if network == "ws":
            ws = stream.get("wsSettings", {})
            params["path"] = ws.get("path", "/")
            params["host"] = ws.get("headers", {}).get("Host", "")
        elif network == "grpc":
            grpc = stream.get("grpcSettings", {})
            params["serviceName"] = grpc.get("serviceName", "")
        elif network == "tcp":
            tcp = stream.get("tcpSettings", {})
            params["headerType"] = tcp.get("header", {}).get("type", "none")

        query = "&".join([f"{k}={urllib.parse.quote(str(v))}" for k, v in params.items() if str(v) != ""])
        return f"vless://{user.get('id','')}@{vnext.get('address','')}:{vnext.get('port',0)}?{query}#{urllib.parse.quote(tag)}"
    except Exception:
        return None


def export_v2rayn_subscription():
    nodes = get_nodes()
    if not nodes:
        print("当前没有可导出的节点")
        return
    lines = []
    for node in nodes:
        uri = outbound_to_vless_uri(node)
        if uri:
            lines.append(uri)
    if not lines:
        print("没有可导出的 vless 节点")
        return
    DATA_DIR.mkdir(parents=True, exist_ok=True)
    raw_path = DATA_DIR / "v2rayn_subscription_raw.txt"
    b64_path = DATA_DIR / "v2rayn_subscription.txt"
    raw_text = "\n".join(lines) + "\n"
    atomic_write_text(raw_path, raw_text, mode=0o600)
    atomic_write_text(b64_path, base64.b64encode(raw_text.encode()).decode() + "\n", mode=0o600)
    print("已导出 v2rayN 订阅:")
    print(f"  原始链接: {raw_path}")
    print(f"  Base64订阅: {b64_path}")


def add_subscription(url, name=None):
    subs = load_subscriptions()
    for item in subs:
        if item.get("url") == url:
            print("订阅已存在，开始更新...")
            return import_from_subscriptions(verbose=True)
    if not name:
        parsed = urlparse(url)
        name = parsed.netloc or f"sub-{len(subs)+1}"
    subs.append({"name": name, "url": url, "enabled": True})
    save_subscriptions(subs)
    print(f"已添加订阅: {name}")
    return import_from_subscriptions(verbose=True)


def list_subscriptions():
    subs = load_subscriptions()
    print(f"\n{'='*56}")
    print("  订阅列表")
    print(f"{'='*56}")
    if not subs:
        print("  (空)")
    for i, sub in enumerate(subs, 1):
        status = "启用" if sub.get("enabled", True) else "禁用"
        print(f"  {i}. [{status}] {sub.get('name') or '未命名'}")
        print(f"     {sub.get('url', '')}")
    print(f"{'='*56}\n")


def remove_subscription(index_text):
    subs = load_subscriptions()
    if not subs:
        print("没有可删除的订阅")
        return False
    try:
        idx = int(index_text) - 1
    except ValueError:
        print("订阅编号必须是数字")
        return False
    if idx < 0 or idx >= len(subs):
        print(f"无效订阅编号: {index_text}")
        return False
    removed = subs.pop(idx)
    save_subscriptions(subs)
    print(f"已删除订阅: {removed.get('name') or removed.get('url')}")
    if subs:
        return import_from_subscriptions(verbose=True)
    save_config(base_config())
    print("订阅已清空，节点列表已清空")
    return True


def set_proxy_mode(mode):
    runtime = require_service()
    if runtime is None:
        cleanup_env_file()
        clear_global_env_file()
        print("模式切换失败，已清理代理环境变量")
        return False
    if not ensure_proxy_running(runtime):
        cleanup_env_file()
        clear_global_env_file()
        print("模式切换失败，已清理代理环境变量，避免程序连接失效的本地代理端口")
        return False

    apply_mode(mode)
    print(f"已切换模式: {MODE_LABELS.get(mode, mode)}")
    print(f"  服务: {runtime['service']}  ● RUNNING")
    print(f"  入站已就绪: socks5://127.0.0.1:{SOCKS_PORT}  http://127.0.0.1:{HTTP_PORT}")
    if mode == "inbound":
        print(f"  仅监听本地入站: socks5://127.0.0.1:{SOCKS_PORT}  http://127.0.0.1:{HTTP_PORT}")
        print("  不写入 shell / 系统环境变量")
    elif mode == "outbound":
        print(f"  写入 shell 环境变量: {PROXY_SH}")
        print(f"  当前 shell 需执行: source {PROXY_SH}")
    elif mode == "global":
        print(f"  写入 shell 环境变量: {PROXY_SH} + {ENV_FILE}")
        print("  新登录 shell / 会话会自动带代理环境变量")
    return True


