def require_service():
    runtime = detect_runtime()
    if run(["systemctl", "cat", runtime["service"]], timeout=8).returncode != 0:
        print(f"未检测到可用服务: {runtime['service']}")
        print("可先执行: proxy 04")
        return None
    return runtime


def restart_service_if_available():
    runtime = detect_runtime()
    try:
        result = run(["systemctl", "cat", runtime["service"]], timeout=8)
    except Exception:
        result = None
    if result is None or result.returncode != 0:
        print("配置已保存；当前未检测到可用服务，可安装 Xray/V2Ray 后执行: proxy on")
        return True
    return restart_proxy_service(runtime)



def switch_node(tag):
    runtime = require_service()
    if runtime is None:
        return
    cfg = load_config()
    valid_tags = [n.get("tag") for n in cfg.get("outbounds", [])]
    if tag not in valid_tags:
        print(f"未知节点: {tag}")
        print(f"可用节点: {', '.join(valid_tags)}")
        sys.exit(1)
    old_routing = cfg.get("routing", {})
    cfg["routing"] = {
        "domainStrategy": "IPIfNonMatch",
        "rules": [{"type": "field", "outboundTag": tag, "port": "0-65535"}],
    }
    save_config(cfg)
    if not restart_proxy_service(runtime):
        cfg["routing"] = old_routing
        save_config(cfg)
        restart_proxy_service(runtime, verify=False)
        print("节点切换失败，已恢复原路由配置")
        return False
    print(f"已切换到 [{tag}]")
    print("  仅入站模式不会自动检测代理出口 IP；如需测试节点出口，请手动执行: proxy 0")
    return True


