def check_inbound_proxy():
    print("检查入站代理是否生效 ...", flush=True)
    runtime = detect_runtime()
    service_active = check_service()
    public_ip = get_public_ip_for_display()
    listens = inbound_listen_addresses()
    current = get_current_tag()

    print(f"  当前节点: {current}", flush=True)
    print(f"  本机公网 IP: {public_ip}", flush=True)
    for proto, listen, port in listens:
        scope = "仅本机" if listen in {"127.0.0.1", "::1", "localhost"} else "可被外部访问(取决于防火墙/安全组)"
        public_addr = f"{public_ip}:{port}" if public_ip != "未知" else f"<公网IP>:{port}"
        print(f"  {proto} 入站监听: {listen}:{port}  |  范围: {scope}", flush=True)
        if listen in {"127.0.0.1", "::1", "localhost"}:
            print(f"    公网入口展示: {public_addr}（当前未公网监听，外部不能直接连）", flush=True)
        else:
            print(f"    公网入口地址: {public_addr}", flush=True)

    print(f"  服务: {runtime['service']}  {'● RUNNING' if service_active else '○ STOPPED'}", flush=True)
    if not service_active:
        print("  结论: 服务未运行，请先执行: proxy on", flush=True)
        return False

    ok = True
    r = subprocess.run(["ss", "-lntp"], capture_output=True, text=True, timeout=5)
    ss_out = r.stdout
    for port, name in [(SOCKS_PORT, "SOCKS5"), (HTTP_PORT, "HTTP")]:
        listening = f"127.0.0.1:{port}" in ss_out or f"0.0.0.0:{port}" in ss_out or f"[::1]:{port}" in ss_out or f":{port}" in ss_out
        print(f"  {name} 端口监听 {port}: {'OK' if listening else 'FAIL'}", flush=True)
        if not listening:
            ok = False

    try:
        with socket.create_connection(("127.0.0.1", SOCKS_PORT), timeout=3) as sock:
            sock.settimeout(3)
            sock.sendall(b"\x05\x01\x00")
            resp = sock.recv(2)
        if resp == b"\x05\x00":
            print("  SOCKS5 入站握手: OK", flush=True)
        else:
            ok = False
            print(f"  SOCKS5 入站握手: FAIL ({resp!r})", flush=True)
    except Exception as e:
        ok = False
        print(f"  SOCKS5 入站握手: FAIL ({e})", flush=True)

    try:
        with socket.create_connection(("127.0.0.1", HTTP_PORT), timeout=3):
            pass
        print("  HTTP 入站 TCP 连接: OK", flush=True)
    except Exception as e:
        ok = False
        print(f"  HTTP 入站 TCP 连接: FAIL ({e})", flush=True)

    print("  端到端出口验证:", flush=True)
    direct_data, direct_src, direct_err = fetch_ip_json(["curl", "--noproxy", "*"], timeout=8)
    if direct_data:
        print_compact_ip("直连出口", direct_data, direct_src)
    else:
        print(f"  直连出口: FAIL ({direct_err})", flush=True)

    socks_data, socks_src, socks_err = fetch_ip_json(["curl", "-x", f"socks5h://127.0.0.1:{SOCKS_PORT}"], timeout=10)
    if socks_data:
        print_compact_ip("SOCKS5 入站代理出口", socks_data, socks_src)
    else:
        ok = False
        print(f"  SOCKS5 入站代理出口: FAIL ({socks_err})", flush=True)

    http_data, http_src, http_err = fetch_ip_json(["curl", "-x", f"http://127.0.0.1:{HTTP_PORT}"], timeout=10)
    if http_data:
        print_compact_ip("HTTP 入站代理出口", http_data, http_src)
    else:
        ok = False
        print(f"  HTTP 入站代理出口: FAIL ({http_err})", flush=True)

    if socks_data and direct_data:
        dip = direct_data.get("query") or direct_data.get("ip") or direct_data.get("origin")
        pip = socks_data.get("query") or socks_data.get("ip") or socks_data.get("origin")
        if dip and pip and dip != pip:
            print(f"  证明: 入站代理已生效，流量从代理 IP {pip} 进口，不是本机直连 {dip}", flush=True)
        elif dip and pip:
            print(f"  说明: 入站代理可用，但代理出口 IP 与本机直连相同: {pip}", flush=True)

    print(f"  结论: {'入站代理正常' if ok else '入站代理异常'}", flush=True)
    return ok

def check_system_proxy():
    print("检查系统出站代理状态 ...")
    profile_exists = os.path.exists(PROXY_SH)
    env_lines = []
    if os.path.exists(ENV_FILE):
        env_lines = [line for line in Path(ENV_FILE).read_text().splitlines() if re.match(r"(?i)^(http|https|all)_proxy=", line.strip())]
    proc_env = {k: v for k, v in os.environ.items() if k.lower() in {"http_proxy", "https_proxy", "all_proxy"}}

    print(f"  模式文件: {MODE_LABELS.get(get_mode(), get_mode())}")
    print(f"  {PROXY_SH}: {'存在' if profile_exists else '不存在'}")
    print(f"  {ENV_FILE} 代理变量: {len(env_lines)} 条")
    print(f"  当前进程代理环境变量: {len(proc_env)} 条")

    if profile_exists or env_lines or proc_env:
        print("  结论: 检测到系统/ shell 出站代理痕迹")
        if profile_exists:
            print(f"    - {PROXY_SH}")
        for line in env_lines:
            print(f"    - {ENV_FILE}: {line}")
        for k, v in sorted(proc_env.items()):
            print(f"    - env: {k}={v}")
    else:
        print("  结论: 未检测到系统/ shell 出站代理环境变量")

    print_direct_ip(prefix="  直连")

def install_official_xray():
    url = "https://github.com/XTLS/Xray-install/raw/main/install-release.sh"
    DATA_DIR.mkdir(parents=True, exist_ok=True)
    tmp = DATA_DIR / f".install_xray_{int(time.time())}.sh"
    print("开始下载官方 Xray 安装脚本...")
    try:
        req = urllib.request.Request(url, headers={"User-Agent": "Mozilla/5.0"})
        with urllib.request.urlopen(req, timeout=30) as resp:
            tmp.write_bytes(resp.read())
        tmp.chmod(0o700)
        print(f"已生成临时脚本: {tmp}")
        res = subprocess.run(["bash", str(tmp), "install"], text=True)
        if res.returncode != 0:
            print("官方安装脚本执行失败")
            sys.exit(res.returncode)
        print("官方 Xray 安装完成")
        runtime = detect_runtime()
        print(f"  服务: {runtime['service']}")
        print(f"  配置: {runtime['config_file']}")
    finally:
        if tmp.exists():
            tmp.unlink()
            print("临时安装脚本已删除")


def main():
    ensure_subscriptions_file()
    ensure_mode_file()

    if len(sys.argv) == 1:
        list_nodes()
        return

    args = sys.argv[1:]
    i = 0
    while i < len(args):
        cmd = args[i].lower()

        if cmd == "000":
            ok = import_from_subscriptions(verbose=True)
            if not ok or not restart_service_if_available():
                sys.exit(1)
            i += 1
        elif cmd == "001":
            list_subscriptions()
            i += 1
        elif cmd == "002":
            if i + 1 >= len(args):
                print("用法: proxy 002 <订阅编号>")
                sys.exit(1)
            ok = remove_subscription(args[i + 1])
            if not ok:
                sys.exit(1)
            if get_nodes():
                if not restart_service_if_available():
                    sys.exit(1)
            elif not stop_proxy():
                sys.exit(1)
            i += 2
        elif cmd == "00":
            if i + 1 >= len(args):
                print("用法: proxy 00 <订阅链接> [名称]")
                sys.exit(1)
            url = args[i + 1]
            name = None
            consumed = 2
            if i + 2 < len(args):
                nxt = args[i + 2].lower()
                if nxt not in ACTION_TOKENS and resolve_tag(args[i + 2]) is None:
                    name = args[i + 2]
                    consumed = 3
            ok = add_subscription(url, name)
            if not ok or not restart_service_if_available():
                sys.exit(1)
            i += consumed
        elif cmd == "01":
            if not set_proxy_mode("inbound"):
                sys.exit(1)
            i += 1
        elif cmd == "02":
            if not set_proxy_mode("outbound"):
                sys.exit(1)
            i += 1
        elif cmd == "03":
            if not set_proxy_mode("global"):
                sys.exit(1)
            i += 1
        elif cmd == "04":
            install_official_xray()
            i += 1
        elif cmd == "05":
            export_v2rayn_subscription()
            i += 1
        elif cmd == "0":
            test_current_ip()
            i += 1
        elif cmd == "06":
            check_inbound_proxy()
            i += 1
        elif cmd == "check":
            check_system_proxy()
            i += 1
        elif cmd in ("off", "stop"):
            if not stop_proxy():
                sys.exit(1)
            i += 1
        elif cmd in ("on", "start"):
            if not start_proxy():
                sys.exit(1)
            i += 1
        elif cmd == "test":
            if i + 1 >= len(args):
                print("用法: proxy test <序号|tag>")
                sys.exit(1)
            tag = resolve_tag(args[i + 1])
            if tag is None:
                print(f"无效参数: {args[i + 1]}")
                sys.exit(1)
            if not test_node(tag):
                sys.exit(1)
            i += 2
        else:
            tag = resolve_tag(cmd)
            if tag is None:
                nodes = get_nodes()
                valid_tags = [n["tag"] for n in nodes]
                print(f"未知: {cmd}")
                print(f"可用: 000 / 00 / 001 / 002 / 01 / 02 / 03 / 04 / 05 / 0 / 序号 1-{len(nodes)} / {', '.join(valid_tags)}")
                sys.exit(1)
            if not switch_node(tag):
                sys.exit(1)
            i += 1


