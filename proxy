def install_official_xray():
    url = "https://github.com/XTLS/Xray-install/raw/main/install-release.sh"
    tmp = BASE_DIR / f".install_xray_{int(time.time())}.sh"
    print("开始下载官方 Xray 安装脚本...")
    try:
        req = urllib.request.Request(url, headers={"User-Agent": "Mozilla/5.0"})
        with urllib.request.urlopen(req, timeout=30) as resp:
            tmp.write_bytes(resp.read())
        tmp.chmod(0o700)
        print(f"已生成临时脚本: {tmp}")
        res = subprocess.run(["bash", str(tmp), "install"], text=True)
        if res.returncode != 0:
            print("官方安装脚本执行失败")
            sys.exit(res.returncode)
        print("官方 Xray 安装完成")
        runtime = detect_runtime()
        print(f"  服务: {runtime['service']}")
        print(f"  配置: {runtime['config_file']}")
    finally:
        if tmp.exists():
            tmp.unlink()
            print("临时安装脚本已删除")


def main():
    ensure_subscriptions_file()
    ensure_mode_file()

    if len(sys.argv) == 1:
        list_nodes()
        return

    args = sys.argv[1:]
    i = 0
    while i < len(args):
        cmd = args[i].lower()

        if cmd == "000":
            ok = import_from_subscriptions(verbose=True)
            if ok:
                runtime = require_service()
                if runtime:
                    subprocess.run(["systemctl", "restart", runtime["service"]], capture_output=True, timeout=15)
            i += 1
        elif cmd == "001":
            list_subscriptions()
            i += 1
        elif cmd == "002":
            if i + 1 >= len(args):
                print("用法: proxy 002 <订阅编号>")
                sys.exit(1)
            ok = remove_subscription(args[i + 1])
            if ok:
                runtime = require_service()
                if runtime:
                    subprocess.run(["systemctl", "restart", runtime["service"]], capture_output=True, timeout=15)
            i += 2
        elif cmd == "00":
            if i + 1 >= len(args):
                print("用法: proxy 00 <订阅链接> [名称]")
                sys.exit(1)
            url = args[i + 1]
            name = None
            consumed = 2
            if i + 2 < len(args):
                nxt = args[i + 2].lower()
                if nxt not in ACTION_TOKENS and resolve_tag(args[i + 2]) is None:
                    name = args[i + 2]
                    consumed = 3
            ok = add_subscription(url, name)
            if ok:
                runtime = require_service()
                if runtime:
                    subprocess.run(["systemctl", "restart", runtime["service"]], capture_output=True, timeout=15)
            i += consumed
        elif cmd == "01":
            set_proxy_mode("inbound")
            i += 1
        elif cmd == "02":
            set_proxy_mode("outbound")
            i += 1
        elif cmd == "03":
            set_proxy_mode("global")
            i += 1
        elif cmd == "04":
            install_official_xray()
            i += 1
        elif cmd == "05":
            export_v2rayn_subscription()
            i += 1
        elif cmd == "0":
            test_current_ip()
            i += 1
        elif cmd == "06":
            check_inbound_proxy()
            i += 1
        elif cmd == "check":
            check_system_proxy()
            i += 1
        elif cmd in ("off", "stop"):
            stop_proxy()
            i += 1
        elif cmd in ("on", "start"):
            start_proxy()
            i += 1
        elif cmd == "test":
            if i + 1 >= len(args):
                print("用法: proxy test <序号|tag>")
                sys.exit(1)
            tag = resolve_tag(args[i + 1])
            if tag is None:
                print(f"无效参数: {args[i + 1]}")
                sys.exit(1)
            test_node(tag)
            i += 2
        else:
            tag = resolve_tag(cmd)
            if tag is None:
                nodes = get_nodes()
                valid_tags = [n["tag"] for n in nodes]
                print(f"未知: {cmd}")
                print(f"可用: 000 / 00 / 001 / 002 / 01 / 02 / 03 / 04 / 05 / 0 / 序号 1-{len(nodes)} / {', '.join(valid_tags)}")
                sys.exit(1)
            switch_node(tag)
            i += 1


if __name__ == "__main__":
