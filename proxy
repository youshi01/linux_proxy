def get_public_ip_for_display():
    urls = [
        "https://api.ipify.org",
        "https://ifconfig.me/ip",
        "http://ip-api.com/line/?fields=query",
    ]
    clean_env = {k: v for k, v in os.environ.items() if k.lower() not in {"http_proxy", "https_proxy", "all_proxy"}}
    for url in urls:
        try:
            r = subprocess.run(
                ["curl", "--noproxy", "*", "-fsS", "--max-time", "6", url],
                capture_output=True, text=True, timeout=9, env=clean_env,
            )
            ip = r.stdout.strip().splitlines()[0] if r.returncode == 0 and r.stdout.strip() else ""
            if re.match(r"^[0-9a-fA-F:.]+$", ip):
                return ip
        except Exception:
            pass
    return "未知"


def inbound_listen_addresses():
    cfg = load_config()
    items = []
    for inbound in cfg.get("inbounds", []):
        proto = str(inbound.get("protocol", "?")).upper()
        listen = inbound.get("listen", "0.0.0.0") or "0.0.0.0"
        port = inbound.get("port", "?")
        items.append((proto, listen, port))
    return items


def fetch_ip_json(cmd_prefix, timeout=10):
    endpoints = [
        "https://ipinfo.io/json",
        "https://api.ipify.org?format=json",
        "https://ifconfig.co/json",
        "https://cloudflare.com/cdn-cgi/trace",
        "http://ip-api.com/json/?lang=zh-CN",
    ]
    last_error = ""
    for url in endpoints:
        try:
            r = subprocess.run(
                cmd_prefix + ["-sS", "--connect-timeout", "3", "--max-time", str(timeout), url],
                capture_output=True, text=True, timeout=timeout + 3,
            )
            body = r.stdout.strip()
            if r.returncode == 0 and body:
                try:
                    return json.loads(body), url, ""
                except Exception:
                    if re.match(r"^[0-9a-fA-F:.]+$", body):
                        return {"ip": body}, url, ""
                    m = re.search(r"(?m)^ip=([^\n]+)", body)
                    if m:
                        return {"ip": m.group(1).strip()}, url, ""
                    last_error = body[:200]
            else:
                last_error = r.stderr.strip() or body or f"curl exit {r.returncode}"
        except Exception as e:
            last_error = str(e)
    return None, "", last_error


def print_compact_ip(label, data, source=None):
    ip = data.get("query") or data.get("ip") or data.get("origin") or "?"
    country = data.get("country") or data.get("country_name") or "?"
    cc = data.get("countryCode") or data.get("country_code") or "?"
    city = data.get("city") or "?"
    isp = data.get("isp") or data.get("org") or "?"
    print(f"  {label}: {ip}  {country}({cc})  {city}  {isp}", flush=True)
    if source:
        print(f"    检测源: {source}", flush=True)

def check_inbound_proxy():
    print("检查入站代理是否生效 ...", flush=True)
    runtime = detect_runtime()
    service_active = check_service()
    public_ip = get_public_ip_for_display()
    listens = inbound_listen_addresses()
    current = get_current_tag()

    print(f"  当前节点: {current}", flush=True)
    print(f"  本机公网 IP: {public_ip}", flush=True)
    for proto, listen, port in listens:
        scope = "仅本机" if listen in {"127.0.0.1", "::1", "localhost"} else "可被外部访问(取决于防火墙/安全组)"
        public_addr = f"{public_ip}:{port}" if public_ip != "未知" else f"<公网IP>:{port}"
        print(f"  {proto} 入站监听: {listen}:{port}  |  范围: {scope}", flush=True)
        if listen in {"127.0.0.1", "::1", "localhost"}:
            print(f"    公网入口展示: {public_addr}（当前未公网监听，外部不能直接连）", flush=True)
        else:
            print(f"    公网入口地址: {public_addr}", flush=True)

    print(f"  服务: {runtime['service']}  {'● RUNNING' if service_active else '○ STOPPED'}", flush=True)
    if not service_active:
        print("  结论: 服务未运行，请先执行: proxy on", flush=True)
        return False

    ok = True
    r = subprocess.run(["ss", "-lntp"], capture_output=True, text=True, timeout=5)
    ss_out = r.stdout
    for port, name in [(SOCKS_PORT, "SOCKS5"), (HTTP_PORT, "HTTP")]:
        listening = f"127.0.0.1:{port}" in ss_out or f"0.0.0.0:{port}" in ss_out or f"[::1]:{port}" in ss_out or f":{port}" in ss_out
        print(f"  {name} 端口监听 {port}: {'OK' if listening else 'FAIL'}", flush=True)
        if not listening:
            ok = False

    try:
        with socket.create_connection(("127.0.0.1", SOCKS_PORT), timeout=3) as sock:
            sock.settimeout(3)
            sock.sendall(b"\x05\x01\x00")
            resp = sock.recv(2)
        if resp == b"\x05\x00":
            print("  SOCKS5 入站握手: OK", flush=True)
        else:
            ok = False
            print(f"  SOCKS5 入站握手: FAIL ({resp!r})", flush=True)
    except Exception as e:
        ok = False
        print(f"  SOCKS5 入站握手: FAIL ({e})", flush=True)

    try:
        with socket.create_connection(("127.0.0.1", HTTP_PORT), timeout=3):
            pass
        print("  HTTP 入站 TCP 连接: OK", flush=True)
    except Exception as e:
        ok = False
        print(f"  HTTP 入站 TCP 连接: FAIL ({e})", flush=True)

    print("  端到端出口验证:", flush=True)
    direct_data, direct_src, direct_err = fetch_ip_json(["curl", "--noproxy", "*"], timeout=8)
    if direct_data:
        print_compact_ip("直连出口", direct_data, direct_src)
    else:
        print(f"  直连出口: FAIL ({direct_err})", flush=True)

    socks_data, socks_src, socks_err = fetch_ip_json(["curl", "-x", f"socks5h://127.0.0.1:{SOCKS_PORT}"], timeout=10)
    if socks_data:
        print_compact_ip("SOCKS5 入站代理出口", socks_data, socks_src)
    else:
        ok = False
        print(f"  SOCKS5 入站代理出口: FAIL ({socks_err})", flush=True)

    http_data, http_src, http_err = fetch_ip_json(["curl", "-x", f"http://127.0.0.1:{HTTP_PORT}"], timeout=10)
    if http_data:
        print_compact_ip("HTTP 入站代理出口", http_data, http_src)
    else:
        ok = False
        print(f"  HTTP 入站代理出口: FAIL ({http_err})", flush=True)

    if socks_data and direct_data:
        dip = direct_data.get("query") or direct_data.get("ip") or direct_data.get("origin")
        pip = socks_data.get("query") or socks_data.get("ip") or socks_data.get("origin")
        if dip and pip and dip != pip:
            print(f"  证明: 入站代理已生效，流量从代理 IP {pip} 进口，不是本机直连 {dip}", flush=True)
        elif dip and pip:
            print(f"  说明: 入站代理可用，但代理出口 IP 与本机直连相同: {pip}", flush=True)

    print(f"  结论: {'入站代理正常' if ok else '入站代理异常'}", flush=True)
    return ok

