def get_public_ip_for_display():
    urls = [
        "https://api.ipify.org",
        "https://ifconfig.me/ip",
        "http://ip-api.com/line/?fields=query",
    ]
    clean_env = {k: v for k, v in os.environ.items() if k.lower() not in {"http_proxy", "https_proxy", "all_proxy"}}
    for url in urls:
        try:
            r = subprocess.run(
                ["curl", "--noproxy", "*", "-fsS", "--max-time", "6", url],
                capture_output=True, text=True, timeout=9, env=clean_env,
            )
            ip = r.stdout.strip().splitlines()[0] if r.returncode == 0 and r.stdout.strip() else ""
            if re.match(r"^[0-9a-fA-F:.]+$", ip):
                return ip
        except Exception:
            pass
    return "未知"


def inbound_listen_addresses():
    cfg = load_config()
    items = []
    for inbound in cfg.get("inbounds", []):
        proto = str(inbound.get("protocol", "?")).upper()
        listen = inbound.get("listen", "0.0.0.0") or "0.0.0.0"
        port = inbound.get("port", "?")
        items.append((proto, listen, port))
    return items


def fetch_ip_json(cmd_prefix, timeout=10):
    endpoints = [
        "https://ipinfo.io/json",
        "https://api.ipify.org?format=json",
        "https://ifconfig.co/json",
        "https://cloudflare.com/cdn-cgi/trace",
        "http://ip-api.com/json/?lang=zh-CN",
    ]
    last_error = ""
    for url in endpoints:
        try:
            r = subprocess.run(
                cmd_prefix + ["-sS", "--connect-timeout", "3", "--max-time", str(timeout), url],
                capture_output=True, text=True, timeout=timeout + 3,
            )
            body = r.stdout.strip()
            if r.returncode == 0 and body:
                try:
                    return json.loads(body), url, ""
                except Exception:
                    if re.match(r"^[0-9a-fA-F:.]+$", body):
                        return {"ip": body}, url, ""
                    m = re.search(r"(?m)^ip=([^\n]+)", body)
                    if m:
                        return {"ip": m.group(1).strip()}, url, ""
                    last_error = body[:200]
            else:
                last_error = r.stderr.strip() or body or f"curl exit {r.returncode}"
        except Exception as e:
            last_error = str(e)
    return None, "", last_error


def print_compact_ip(label, data, source=None):
