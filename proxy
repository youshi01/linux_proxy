def require_service():
    runtime = detect_runtime()
    if run(["systemctl", "cat", runtime["service"]], timeout=8).returncode != 0:
        print(f"未检测到可用服务: {runtime['service']}")
        print("可先执行: proxy 04")
        return None
    return runtime



def switch_node(tag):
    runtime = require_service()
    if runtime is None:
        return
    cfg = load_config()
    valid_tags = [n.get("tag") for n in cfg.get("outbounds", [])]
    if tag not in valid_tags:
        print(f"未知节点: {tag}")
        print(f"可用节点: {', '.join(valid_tags)}")
        sys.exit(1)
    cfg["routing"] = {
        "domainStrategy": "IPIfNonMatch",
        "rules": [{"type": "field", "outboundTag": tag, "port": "0-65535"}],
    }
    save_config(cfg)
    subprocess.run(["systemctl", "restart", runtime["service"]], capture_output=True, timeout=15)
    time.sleep(0.5)
    print(f"已切换到 [{tag}]")
    print("  仅入站模式不会自动检测代理出口 IP；如需测试节点出口，请手动执行: proxy 0")


def start_proxy():
    runtime = require_service()
    if runtime is None:
        return
    apply_mode(get_mode())
    subprocess.run(["systemctl", "enable", runtime["service"], "--now"], capture_output=True, timeout=15)
    print("代理已启动")
    print(f"  当前模式: {MODE_LABELS.get(get_mode(), get_mode())}")
    print(f"  服务: {runtime['service']}  |  配置: {runtime['config_file']}")
    print(f"  本地监听: socks5://127.0.0.1:{SOCKS_PORT}  http://127.0.0.1:{HTTP_PORT}")


def stop_proxy():
    runtime = detect_runtime()
    subprocess.run(["systemctl", "stop", runtime["service"]], capture_output=True, timeout=15)
    subprocess.run(["systemctl", "disable", runtime["service"]], capture_output=True, timeout=15)
    cleanup_env_file()
    clear_global_env_file()
    print("代理已停止")
    print("  已关闭本地监听，并清理 shell / 系统代理环境变量")




def print_ip_result(data, source=None, prefix="  "):
    ip = data.get("query") or data.get("ip") or data.get("origin") or "?"
    print(f"{prefix}IP:    {ip}")
    if data.get("country") or data.get("countryCode"):
        print(f"{prefix}国家:  {data.get('country', '?')} ({data.get('countryCode', '?')})")
    if data.get("city"):
        print(f"{prefix}城市:  {data.get('city', '?')}")
    if data.get("isp") or data.get("org"):
        print(f"{prefix}ISP:   {data.get('isp') or data.get('org')}")
    if source:
        print(f"{prefix}检测源: {source}")


def print_direct_ip(prefix="  直连"):
    endpoints = [
        "https://ipinfo.io/json",
        "https://api.ipify.org?format=json",
        "https://ifconfig.co/json",
        "https://cloudflare.com/cdn-cgi/trace",
        "http://ip-api.com/json/?lang=zh-CN",
    ]
    clean_env = {k: v for k, v in os.environ.items() if k.lower() not in {"http_proxy", "https_proxy", "all_proxy"}}
    for url in endpoints:
        try:
            result = subprocess.run(
                ["curl", "--noproxy", "*", "-sS", "--max-time", "8", url],
                capture_output=True, text=True, timeout=11, env=clean_env,
            )
            body = result.stdout.strip()
            if result.returncode == 0 and body:
                data = json.loads(body)
                print(f"{prefix}出口 IP：")
                print_ip_result(data, url, prefix="    ")
                return True
        except Exception:
            pass
    print(f"{prefix}出口 IP 检测失败")
    return False

def check_node_tcp(tag, timeout=2):
    cfg = load_config()
    for node in cfg.get("outbounds", []):
        if node.get("tag") != tag:
            continue
        vnext = node.get("settings", {}).get("vnext", [{}])[0]
        host = vnext.get("address", "")
        port = int(vnext.get("port", 0) or 0)
        try:
            with socket.create_connection((host, port), timeout=timeout):
                return True, f"{host}:{port}", ""
        except Exception as e:
            return False, f"{host}:{port}", f"{type(e).__name__}: {e}"
    return False, "", "节点不存在"


def curl_via_proxy(url, timeout=6):
    return subprocess.run(
        [
            "curl", "-x", f"socks5h://127.0.0.1:{SOCKS_PORT}",
            "-sS", "--max-time", str(timeout), url,
        ],
        capture_output=True, text=True, timeout=timeout + 3,
    )


def test_proxy_ip(tag=None):
    if not check_service():
        print("代理未运行，请先执行 proxy on")
        return False
