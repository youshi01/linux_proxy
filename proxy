import json
import os
import re
import shutil
import socket
import subprocess
import sys
import time
import urllib.error
import urllib.request
from pathlib import Path
from urllib.parse import parse_qs, unquote, urlparse

BASE_DIR = Path(__file__).resolve().parent
SUBS_FILE = str(BASE_DIR / "proxy_subscriptions.json")
MODE_FILE = str(BASE_DIR / "proxy_mode.json")
PROXY_SH = "/etc/profile.d/xray-proxy.sh"
ENV_FILE = "/etc/environment"
SOCKS_PORT = 10808
HTTP_PORT = 10809
DEFAULT_MODE = "inbound"

DEFAULT_SUBSCRIPTIONS = []

MODE_LABELS = {
    "inbound": "仅入站代理",
    "outbound": "仅出站代理",
    "global": "全局代理",
}

PROXY_ENV_LINES = [
    f"HTTP_PROXY=http://127.0.0.1:{HTTP_PORT}",
    f"HTTPS_PROXY=http://127.0.0.1:{HTTP_PORT}",
    f"ALL_PROXY=socks5h://127.0.0.1:{SOCKS_PORT}",
    f"http_proxy=http://127.0.0.1:{HTTP_PORT}",
    f"https_proxy=http://127.0.0.1:{HTTP_PORT}",
    f"all_proxy=socks5h://127.0.0.1:{SOCKS_PORT}",
]

SERVICE_CANDIDATES = ["xray-proxy", "xray", "v2ray", "v2ray-proxy"]
CONFIG_CANDIDATES = [
    str(BASE_DIR / "xray_proxy_config.json"),
    "/usr/local/etc/xray/config.json",
    "/etc/xray/config.json",
    "/usr/local/etc/v2ray/config.json",
    "/etc/v2ray/config.json",
]

ACTION_TOKENS = {
    "000", "00", "001", "002", "01", "02", "03", "04", "05",
    "0", "06", "off", "stop", "on", "start", "test", "check"
}


def run(cmd, **kwargs):
    return subprocess.run(cmd, capture_output=True, text=True, **kwargs)


def base_config():
    return {
        "log": {"loglevel": "warning"},
        "inbounds": [
            {
                "listen": "127.0.0.1",
                "port": SOCKS_PORT,
                "protocol": "socks",
                "settings": {"auth": "noauth", "udp": True},
            },
            {
                "listen": "127.0.0.1",
                "port": HTTP_PORT,
                "protocol": "http",
                "settings": {},
            },
        ],
        "outbounds": [],
        "routing": {
            "domainStrategy": "IPIfNonMatch",
            "rules": [{"type": "field", "outboundTag": "", "port": "0-65535"}],
        },
    }


def ensure_subscriptions_file():
    path = Path(SUBS_FILE)
    if not path.exists():
        path.write_text(json.dumps(DEFAULT_SUBSCRIPTIONS, indent=2, ensure_ascii=False) + "\n")


def load_subscriptions():
    ensure_subscriptions_file()
    try:
        data = json.loads(Path(SUBS_FILE).read_text())
        if isinstance(data, list):
            return data
    except Exception:
        pass
    return DEFAULT_SUBSCRIPTIONS.copy()


def save_subscriptions(items):
    Path(SUBS_FILE).write_text(json.dumps(items, indent=2, ensure_ascii=False) + "\n")


def ensure_mode_file():
    path = Path(MODE_FILE)
    if not path.exists():
        path.write_text(json.dumps({"mode": DEFAULT_MODE}, ensure_ascii=False) + "\n")


def get_mode():
    ensure_mode_file()
    try:
        data = json.loads(Path(MODE_FILE).read_text())
        mode = data.get("mode", DEFAULT_MODE)
        if mode in MODE_LABELS:
            return mode
    except Exception:
        pass
    return DEFAULT_MODE


def save_mode(mode):
    Path(MODE_FILE).write_text(json.dumps({"mode": mode}, ensure_ascii=False) + "\n")


def parse_config_path_from_unit(text):
    patterns = [
        r"-config\s+(\S+)",
        r"\s-c\s+(\S+)",
        r"\sconfig\s+(\S+\.json)",
    ]
    for pat in patterns:
        m = re.search(pat, text)
        if m:
            return m.group(1)
    return None


def detect_runtime():
    for service in SERVICE_CANDIDATES:
        r = run(["systemctl", "cat", service], timeout=8)
        if r.returncode == 0:
            cfg = parse_config_path_from_unit(r.stdout)
            if cfg:
                return {"service": service, "config_file": cfg, "source": "systemd"}
            for candidate in CONFIG_CANDIDATES:
                if Path(candidate).exists():
                    return {"service": service, "config_file": candidate, "source": "mixed"}
            return {"service": service, "config_file": CONFIG_CANDIDATES[0], "source": "systemd"}

    for candidate in CONFIG_CANDIDATES:
        if Path(candidate).exists():
            guessed = "xray" if "xray" in candidate else "v2ray"
            return {"service": guessed, "config_file": candidate, "source": "path"}

    return {"service": "xray", "config_file": CONFIG_CANDIDATES[1], "source": "default"}


def load_config():
    runtime = detect_runtime()
    path = Path(runtime["config_file"])
    if not path.exists():
        return base_config()
    with open(path) as f:
        return json.load(f)


def backup_config(path):
    p = Path(path)
    if not p.exists():
        return
    backup = p.with_name(p.name + f".bak.{int(time.time())}")
    shutil.copy2(p, backup)


def save_config(cfg):
    runtime = detect_runtime()
    path = Path(runtime["config_file"])
    path.parent.mkdir(parents=True, exist_ok=True)
    if path.exists():
        backup_config(path)
    with open(path, "w") as f:
        json.dump(cfg, f, indent=2, ensure_ascii=False)


def get_nodes():
    return load_config().get("outbounds", [])


def get_current_tag():
    rules = load_config().get("routing", {}).get("rules", [])
    return rules[0].get("outboundTag", "unknown") if rules else "unknown"


def resolve_tag(arg):
    nodes = get_nodes()
    try:
        idx = int(arg) - 1
        if 0 <= idx < len(nodes):
            return nodes[idx]["tag"]
    except ValueError:
        pass
    valid_tags = [n["tag"] for n in nodes]
    if arg in valid_tags:
        return arg
    return None


def check_service():
    runtime = detect_runtime()
    try:
        r = run(["systemctl", "is-active", runtime["service"]], timeout=5)
        return r.stdout.strip() == "active"
    except Exception:
        return False


def cleanup_env_file():
    if os.path.exists(PROXY_SH):
        os.remove(PROXY_SH)


def remove_env_vars_from_text(text):
    lines = text.splitlines()
    filtered = []
    keys = {line.split("=", 1)[0] for line in PROXY_ENV_LINES}
    for line in lines:
        stripped = line.strip()
        if any(stripped.startswith(k + "=") for k in keys):
            continue
        filtered.append(line)
    return "\n".join(filtered).strip("\n")


def write_profile_env_file():
    content = "\n".join([f"export {line}" for line in PROXY_ENV_LINES]) + "\n"
    with open(PROXY_SH, "w") as f:
        f.write(content)


def write_global_env_file():
    existing = Path(ENV_FILE).read_text() if os.path.exists(ENV_FILE) else ""
    cleaned = remove_env_vars_from_text(existing)
    final = (cleaned + "\n" if cleaned else "") + "\n".join(PROXY_ENV_LINES) + "\n"
    Path(ENV_FILE).write_text(final)


def clear_global_env_file():
    if not os.path.exists(ENV_FILE):
        return
    existing = Path(ENV_FILE).read_text()
    cleaned = remove_env_vars_from_text(existing)
    Path(ENV_FILE).write_text((cleaned + "\n") if cleaned else "")


def apply_mode(mode):
    cleanup_env_file()
    clear_global_env_file()
    if mode == "outbound":
        write_profile_env_file()
    elif mode == "global":
        write_profile_env_file()
        write_global_env_file()
    save_mode(mode)


def unique_tag(tag, seen):
    base = tag or "NODE"
    if base not in seen:
        seen.add(base)
        return base
    i = 2
    while f"{base}-{i}" in seen:
        i += 1
    final = f"{base}-{i}"
    seen.add(final)
    return final


def fetch_subscription_text(url):
    req = urllib.request.Request(url, headers={"User-Agent": "Mozilla/5.0"})
    with urllib.request.urlopen(req, timeout=20) as resp:
        raw = resp.read().decode("utf-8", "ignore").strip()
    try:
        return base64.b64decode(raw + "=" * (-len(raw) % 4)).decode("utf-8", "ignore")
    except Exception:
        return raw


def build_vless_outbound(uri, seen_tags):
    u = urlparse(uri)
    if u.scheme.lower() != "vless":
        return None
    q = parse_qs(u.query)
    tag = unique_tag(unquote(u.fragment) if u.fragment else (u.hostname or "NODE"), seen_tags)
    host = q.get("host", [""])[0]
    path = q.get("path", [""])[0] or q.get("spx", [""])[0] or "/"
    flow = q.get("flow", [""])[0]
    fingerprint = q.get("fp", [""])[0] or "chrome"
    sni = q.get("sni", [""])[0] or q.get("servername", [""])[0]
    network = q.get("type", ["tcp"])[0]

    outbound = {
        "protocol": "vless",
        "settings": {
            "vnext": [
                {
                    "address": u.hostname or "",
                    "port": u.port or 0,
                    "users": [
                        {
                            "id": u.username or "",
                            "encryption": q.get("encryption", ["none"])[0],
                            "flow": flow,
                        }
                    ],
                }
            ]
        },
        "streamSettings": {
            "network": network,
            "security": q.get("security", [""])[0],
            "realitySettings": {
                "serverName": sni,
                "fingerprint": fingerprint,
                "publicKey": q.get("pbk", [""])[0],
                "shortId": q.get("sid", [""])[0],
                "spiderX": q.get("spx", ["/"])[0] or "/",
            },
        },
        "tag": tag,
    }

    if network == "tcp":
        outbound["streamSettings"]["tcpSettings"] = {"header": {"type": "none"}}
    elif network == "ws":
        outbound["streamSettings"]["wsSettings"] = {"path": path, "headers": {"Host": host}}
    elif network == "grpc":
        outbound["streamSettings"]["grpcSettings"] = {"serviceName": path.lstrip("/")}
    return outbound


def import_from_subscriptions(verbose=True):
    subs = [s for s in load_subscriptions() if s.get("enabled", True) and s.get("url")]
    if not subs:
        print("没有可用订阅，请先执行: proxy 00 <订阅链接>")
        return False

    all_nodes = []
    seen_tags = set()
    for sub in subs:
        try:
            text = fetch_subscription_text(sub["url"])
            lines = [x.strip() for x in text.splitlines() if x.strip()]
            imported = 0
            for line in lines:
                node = build_vless_outbound(line, seen_tags)
                if node:
                    all_nodes.append(node)
                    imported += 1
            if verbose:
                print(f"订阅 [{sub.get('name') or '未命名'}] 已更新，导入 {imported} 个节点")
        except urllib.error.HTTPError as e:
            print(f"订阅 [{sub.get('name') or '未命名'}] 更新失败: HTTP {e.code}")
        except Exception as e:
            print(f"订阅 [{sub.get('name') or '未命名'}] 更新失败: {e}")

    if not all_nodes:
        print("没有从订阅中导入任何可用节点")
        return False

    old = load_config()
    cfg = base_config()
    cfg["outbounds"] = all_nodes
    current = old.get("routing", {}).get("rules", [{}])[0].get("outboundTag", "") if old else ""
    valid_tags = [n["tag"] for n in all_nodes]
    selected = current if current in valid_tags else valid_tags[0]
    cfg["routing"]["rules"][0]["outboundTag"] = selected
    save_config(cfg)
    if verbose:
        print(f"已写入 {len(all_nodes)} 个节点，当前节点: {selected}")
    return True


def outbound_to_vless_uri(node):
    try:
        import urllib.parse
        tag = node.get("tag", "NODE")
        vnext = node.get("settings", {}).get("vnext", [{}])[0]
        user = vnext.get("users", [{}])[0]
        stream = node.get("streamSettings", {})
        reality = stream.get("realitySettings", {})
        params = {
            "encryption": user.get("encryption", "none"),
            "type": stream.get("network", "tcp"),
            "security": stream.get("security", ""),
            "flow": user.get("flow", ""),
            "pbk": reality.get("publicKey", ""),
            "sid": reality.get("shortId", ""),
            "sni": reality.get("serverName", ""),
            "fp": reality.get("fingerprint", ""),
            "spx": reality.get("spiderX", "/"),
        }
        query = "&".join([f"{k}={urllib.parse.quote(str(v))}" for k, v in params.items() if str(v) != ""])
        return f"vless://{user.get('id','')}@{vnext.get('address','')}:{vnext.get('port',0)}?{query}#{urllib.parse.quote(tag)}"
    except Exception:
        return None


def export_v2rayn_subscription():
    nodes = get_nodes()
    if not nodes:
        print("当前没有可导出的节点")
        return
    lines = []
    for node in nodes:
        uri = outbound_to_vless_uri(node)
        if uri:
            lines.append(uri)
    if not lines:
        print("没有可导出的 vless 节点")
        return
    raw_path = BASE_DIR / "v2rayn_subscription_raw.txt"
    b64_path = BASE_DIR / "v2rayn_subscription.txt"
    raw_text = "\n".join(lines) + "\n"
    raw_path.write_text(raw_text)
    b64_path.write_text(base64.b64encode(raw_text.encode()).decode() + "\n")
    print("已导出 v2rayN 订阅:")
    print(f"  原始链接: {raw_path}")
    print(f"  Base64订阅: {b64_path}")


def add_subscription(url, name=None):
    subs = load_subscriptions()
    for item in subs:
        if item.get("url") == url:
            print("订阅已存在，开始更新...")
            return import_from_subscriptions(verbose=True)
    if not name:
        parsed = urlparse(url)
        name = parsed.netloc or f"sub-{len(subs)+1}"
    subs.append({"name": name, "url": url, "enabled": True})
    save_subscriptions(subs)
    print(f"已添加订阅: {name}")
    return import_from_subscriptions(verbose=True)


